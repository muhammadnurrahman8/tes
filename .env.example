# Salin file ini menjadi .env.local untuk pengembangan lokal.
# Nilai-nilai ini didapat otomatis dari dashboard Vercel Postgres
# saat kamu membuat database dan menghubungkannya ke project.

POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Secret untuk menandatangani cookie session login (fitur Auth).
# Ganti dengan string acak yang panjang saat deploy ke production.
SESSION_SECRET=ubah-string-rahasia-ini-di-produksi
